// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js" // Tells Prisma to generate the Prisma Client
}

datasource db {
  provider = "postgresql" // The database type is PostgreSQL
  url      = env("DATABASE_URL")
}

model Roadmap {
  id          Int    @id @default(autoincrement()) // Primary key; if no id is provided, the database automatically generates the next integer
  title       String // Req string col
  description String // Req string col
  difficulty  Int? // Optional integer col (? means nullable)

  topics Topic[]
}

model Topic {
  id Int @id @default(autoincrement())

  title     String
  dayNumber Int

  difficulty Int?
  notes      String?

  status      String
  stuckReason String?

  timeStarted DateTime?
  timeEnded   DateTime?

  roadmapId Int
  roadmap   Roadmap @relation(fields: [roadmapId], references: [id])
}

model File {
  id           Int      @id @default(autoincrement())
  originalName String
  fileName     String
  mimeType     String
  size         Int
  path         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
